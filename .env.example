# Serveur
PORT=3040
DATA_DIR=./data

# Admin (OBLIGATOIRE en prod) : choisir un PIN FORT (>= 8 chiffres, non deviné) + un secret aléatoire fixe.
# Ne jamais laisser le PIN par défaut du code (7351) en prod — l'admin permet CRUD complet des données.
ADMIN_PIN=
ADMIN_SECRET=

# Collecteurs gratuits
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Collecteur principal réseaux fermés — monid.ai (agrège Apify & co, wallet unique)
# Clé sur https://app.monid.ai/access/api-keys (1 $ offert). Facturation PER_CALL, coût réel dans billing.actualCost.
MONID_API_KEY=
MONID_WORKSPACE_ID=
ENABLE_PAID=0

# Legacy — Apify direct (plan B, non utilisé si monid.ai)
APIFY_TOKEN=
