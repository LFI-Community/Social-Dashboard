<%- include('partials/head', { pageTitle: 'Classement' }) %>

<section class="hero">
  <h1>Qui <span class="u">surveiller</span> en priorité</h1>
  <p class="sub">Classement par <strong>score de pertinence</strong> — activité × qualité (engagement) × reach (abonnés) × poids du mandat, fenêtre <%= window %> j. Une ligne = un compte.</p>
  <div class="stats">
    <div class="stat"><span class="n"><%= counts.persons.toLocaleString('fr-FR') %></span><span class="l">personnalités</span></div>
    <div class="stat"><span class="n"><%= counts.accounts.toLocaleString('fr-FR') %></span><span class="l">comptes suivis</span></div>
    <div class="stat"><span class="n"><%= counts.mandates.toLocaleString('fr-FR') %></span><span class="l">mandats</span></div>
  </div>

  <% if (note) { %><div class="demo-banner">🧪 <%= note %></div><% } %>

  <div class="filters">
    <a href="/" class="f-all <%= !party ? 'on' : '' %>"><span class="dot dot-all"></span> Tous</a>
    <% parties.forEach(function(pt){ %>
      <a href="/?party=<%= encodeURIComponent(pt.short) %>" class="<%= party===pt.short ? 'on' : '' %>"
         style="<%= party===pt.short ? 'background:'+pt.color+';border-color:transparent;color:#fff' : '' %>">
        <%- plogo(pt.short, pt.color, pt.name) %> <span class="muted"><%= pt.n %></span>
      </a>
    <% }) %>
  </div>

  <div class="collectors">
    <% collectors.forEach(function(c){ %>
      <span class="chip <%= c.enabled ? 'on' : 'off' %> <%= c.kind %>"><%- icon(c.network, 13) %> <%= NET_LABEL[c.network] || c.network %><% if (c.kind==='paid'){ %> · payant<% } %></span>
    <% }) %>
  </div>
</section>

<% if (rows.length === 0) { %>
  <div class="empty">
    <p>Aucune donnée pour ce filtre.</p>
    <p class="muted">Charger le jeu de démo : <code>npm run seed</code></p>
  </div>
<% } else {
     const maxScore = Math.max.apply(null, rows.map(function(r){return r.watch_score||0})) || 1; %>
  <table class="ranking">
    <thead><tr><th>#</th><th>Personnalité</th><th>Parti</th><th>Réseau</th><th class="num">Abonnés</th><th class="num">Posts/sem.</th><th>Score</th></tr></thead>
    <tbody>
    <% rows.forEach(function(r, i){ %>
      <tr>
        <td class="rank rank-<%= i+1 %>"><% if (i<3) { %><span class="medal"><%= i+1 %></span><% } else { %><%= i+1 %><% } %></td>
        <td><% if (r.person_id) { %><a class="pname" href="/person/<%= r.person_id %>"><%= r.display_name %></a><% } else { %><em>standalone</em><% } %></td>
        <td><%- plogo(r.party_short, r.party_color, r.party_name) %></td>
        <td>
          <span class="net"><%- icon(r.network) %><span class="lab"><%= NET_LABEL[r.network] %></span></span>
          <span class="muted">@<%= r.handle %></span>
        </td>
        <td class="num"><%= fmt(r.followers) %></td>
        <td class="num"><%= (r.posts_per_week || 0).toFixed(1) %></td>
        <td>
          <div class="score">
            <strong><%= (r.watch_score || 0).toFixed(2) %></strong>
            <span class="score-track"><i style="width:<%= Math.round((r.watch_score||0)/maxScore*100) %>%"></i></span>
          </div>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('partials/foot') %>
