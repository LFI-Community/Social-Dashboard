<%- include('partials/head', { pageTitle: 'Classement' }) %>

<section class="hero">
  <h1>Qui <span class="u">surveiller</span> en priorité</h1>
  <p class="sub">Classement par <strong>score de pertinence</strong> — activité × qualité (engagement) × reach (abonnés) × poids du mandat, fenêtre <%= window %> j. Une ligne = une <strong>personnalité</strong> (tous réseaux réunis).</p>
  <div class="stats">
    <div class="stat"><span class="n"><%= counts.persons.toLocaleString('fr-FR') %></span><span class="l">personnalités</span></div>
    <div class="stat"><span class="n"><%= counts.accounts.toLocaleString('fr-FR') %></span><span class="l">comptes suivis</span></div>
    <div class="stat"><span class="n"><%= counts.mandates.toLocaleString('fr-FR') %></span><span class="l">mandats</span></div>
  </div>

  <% if (note) { %><div class="demo-banner">🧪 <%= note %></div><% } %>

  <% const nq = network ? '&network='+network : ''; const pq = party ? '&party='+party : ''; %>
  <div class="filters">
    <a href="/<%= network ? '?network='+network : '' %>" class="f-all <%= !party ? 'on' : '' %>"><span class="dot dot-all"></span> Tous partis</a>
    <% parties.forEach(function(pt){ %>
      <a href="/?party=<%= encodeURIComponent(pt.short) %><%= nq %>" class="<%= party===pt.short ? 'on' : '' %>"
         style="<%= party===pt.short ? 'background:'+pt.color+';border-color:transparent;color:#fff' : '' %>">
        <%- plogo(pt.short, pt.color, pt.name) %> <span class="muted"><%= pt.n %></span>
      </a>
    <% }) %>
  </div>
  <div class="filters">
    <a href="/<%= party ? '?party='+party : '' %>" class="f-all <%= !network ? 'on' : '' %>">Tous réseaux</a>
    <% ['x','instagram','tiktok','youtube','facebook','twitch'].forEach(function(net){ %>
      <a href="/?network=<%= net %><%= pq %>" class="netfilter <%= network===net ? 'on' : '' %>"><%- icon(net,15) %> <%= NET_LABEL[net] %></a>
    <% }) %>
  </div>

  <input id="q" class="search-box" placeholder="🔍 Rechercher une personnalité dans le classement…" autocomplete="off">

  <div class="collectors">
    <% collectors.forEach(function(c){ %>
      <span class="chip <%= c.enabled ? 'on' : 'off' %> <%= c.kind %>"><%- icon(c.network, 13) %> <%= NET_LABEL[c.network] || c.network %><% if (c.kind==='paid'){ %> · payant<% } %></span>
    <% }) %>
  </div>
</section>

<% if (rows.length === 0) { %>
  <div class="empty">
    <p>Aucune donnée pour ce filtre.</p>
    <p class="muted">Charger le jeu de démo : <code>npm run seed</code></p>
  </div>
<% } else {
     const maxScore = Math.max.apply(null, rows.map(function(r){return r.watch_score||0})) || 1; %>
  <table class="ranking">
    <thead><tr><th>#</th><th>Personnalité</th><th>Parti</th><th>Réseaux</th><th class="num">Abonnés</th><th class="num">Posts/sem.</th><th>Score</th></tr></thead>
    <tbody>
    <% rows.forEach(function(r, i){ %>
      <tr data-name="<%= r.display_name %>">
        <td class="rank rank-<%= i+1 %>"><% if (i<3) { %><span class="medal"><%= i+1 %></span><% } else { %><%= i+1 %><% } %></td>
        <td><a class="pname" href="/person/<%= r.person_id %>"><%= r.display_name %></a></td>
        <td><%- plogo(r.party_short, r.party_color, r.party_name) %></td>
        <td>
          <span class="netset">
            <% r.nets.forEach(function(a){ %><a class="netdot" href="<%= a.url %>" target="_blank" rel="noopener" title="<%= NET_LABEL[a.network] %> · @<%= a.handle %> · <%= fmt(a.followers) %> abonnés"><%- icon(a.network, 18) %></a><% }) %>
          </span>
        </td>
        <td class="num"><%= fmt(r.followers) %></td>
        <td class="num"><%= (r.posts_per_week || 0).toFixed(1) %></td>
        <td>
          <div class="score">
            <strong><%= (r.watch_score || 0).toFixed(2) %></strong>
            <span class="score-track"><i style="width:<%= Math.round((r.watch_score||0)/maxScore*100) %>%"></i></span>
          </div>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
<% } %>

<script>
(function(){
  const q=document.getElementById('q'); if(!q) return;
  q.addEventListener('input',function(){
    const v=q.value.toLowerCase().trim();
    let rank=0;
    document.querySelectorAll('table.ranking tbody tr').forEach(function(tr){
      const show=(tr.dataset.name||'').toLowerCase().includes(v);
      tr.style.display=show?'':'none';
      if(show){ rank++; const c=tr.querySelector('.rank'); if(c && !c.querySelector('.medal')) c.textContent=rank; }
    });
  });
})();
</script>

<%- include('partials/foot') %>
