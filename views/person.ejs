<%- include('partials/head', { pageTitle: person.display_name }) %>

<a class="back" href="/">← Classement</a>
<h1 class="title">
  <%= person.display_name %>
  <% if (party) { %><%- plogo(party.short, party.color, party.name) %> <span class="muted" style="font-size:15px;font-weight:700"><%= party.name %></span><% } %>
  <% if (person.is_public_figure) { %><span class="chip">personnalité</span><% } %>
</h1>

<%
  const totalFollowers = accounts.reduce(function(s,a){return s+(a.followers||0)},0);
  const bestScore = accounts.reduce(function(m,a){return Math.max(m,a.watch_score||0)},0);
  const ppw = accounts.reduce(function(s,a){return s+(a.posts_per_week||0)},0);
%>
<div class="stats">
  <div class="stat"><span class="n"><%= fmt(totalFollowers) %></span><span class="l">abonnés cumulés</span></div>
  <div class="stat"><span class="n"><%= ppw.toFixed(0) %></span><span class="l">posts / sem.</span></div>
  <div class="stat"><span class="n"><%= bestScore.toFixed(2) %></span><span class="l">meilleur score</span></div>
  <div class="stat"><span class="n"><%= accounts.length %></span><span class="l">réseaux</span></div>
</div>

<section>
  <h2>Activité (90 j, tous réseaux)</h2>
  <div class="card chart-card"><%- spark(series, 1040, 90) %></div>
</section>

<section>
  <h2>Comptes suivis</h2>
  <% if (accounts.length === 0) { %><p class="muted">Aucun compte rattaché.</p><% } else { %>
    <table class="ranking">
      <thead><tr><th>Réseau</th><th>Handle</th><th class="num">Abonnés</th><th class="num">Posts/sem.</th><th class="num">Score</th></tr></thead>
      <tbody>
      <% accounts.forEach(function(a){ %>
        <tr>
          <td><span class="net"><%- icon(a.network, 20) %><span class="lab"><%= NET_LABEL[a.network] %></span></span></td>
          <td><a href="<%= a.url %>" target="_blank" rel="noopener">@<%= a.handle %></a> <% if (a.tier==='A'){ %><span class="chip">Tier A</span><% } %></td>
          <td class="num"><%= fmt(a.followers) %></td>
          <td class="num"><%= a.posts_per_week != null ? a.posts_per_week.toFixed(1) : '—' %></td>
          <td class="num"><strong><%= a.watch_score != null ? a.watch_score.toFixed(2) : '—' %></strong></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<section>
  <h2>Mandats</h2>
  <% if (mandates.length === 0) { %><p class="muted">Aucun mandat (personnalité hors mandat).</p><% } else { %>
    <ul class="mandates">
      <% mandates.forEach(function(m){ %>
        <li><strong><%= m.function_label || m.mandate_type %></strong> — <%= m.territory_label || m.territory_code %>
          <span class="muted">(poids <%= m.mandate_weight %>)</span></li>
      <% }) %>
    </ul>
  <% } %>
</section>

<% if (hotPosts && hotPosts.length) { %>
<section>
  <h2>Hot posts (par engagement) — cliquer pour ouvrir sur la plateforme</h2>
  <div class="hot-grid">
    <% hotPosts.forEach(function(p){ %>
      <a class="hotcard" href="<%= p.url %>" target="_blank" rel="noopener">
        <div class="hc-head">
          <span class="net"><%- icon(p.network, 18) %><span class="lab"><%= NET_LABEL[p.network] %></span></span>
          <span class="muted"><%= p.posted_at.slice(0,10) %></span>
        </div>
        <div class="hc-body"><%= p.content || '(sans texte)' %></div>
        <div class="hc-meta">
          <% if (p.view_count) { %><span>👁 <%= fmt(p.view_count) %></span><% } %>
          <span class="eng">❤ <%= fmt(p.engagement) %></span>
          <span class="hc-go">Voir le profil ↗</span>
        </div>
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<p class="muted"><a href="/compare?ids=<%= person.id %>">→ Ajouter au comparateur</a></p>

<%- include('partials/foot') %>
