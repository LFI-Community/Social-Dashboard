<%- include('../partials/head', { pageTitle: 'Admin' }) %>

<h1 class="title">Console d'administration</h1>
<p class="sub muted">Gérer la watchlist, les collecteurs et le scoring. <span id="toast" class="muted"></span></p>

<!-- Vue d'ensemble -->
<div class="stats">
  <div class="stat"><span class="n"><%= stats.persons.toLocaleString('fr-FR') %></span><span class="l">personnalités</span></div>
  <div class="stat"><span class="n"><%= stats.accounts.toLocaleString('fr-FR') %></span><span class="l">comptes</span></div>
  <div class="stat"><span class="n"><%= (stats.followers>=1e6 ? (stats.followers/1e6).toFixed(1)+'M' : stats.followers.toLocaleString('fr-FR')) %></span><span class="l">abonnés cumulés</span></div>
  <div class="stat"><span class="n"><%= stats.mandates.toLocaleString('fr-FR') %></span><span class="l">mandats</span></div>
</div>

<div class="admin-grid">
  <!-- Répartition par réseau -->
  <section class="card admin-card">
    <h2>Comptes par réseau</h2>
    <ul class="breakdown">
      <% stats.byNetwork.forEach(function(r){ %>
        <li><span class="net"><%- icon(r.network,18) %><span class="lab"><%= NET_LABEL[r.network]||r.network %></span></span>
          <span class="muted"><%= r.n %> comptes</span>
          <span class="eng num"><%= (r.f>=1e6?(r.f/1e6).toFixed(1)+'M':fmt(r.f)) %></span></li>
      <% }) %>
    </ul>
  </section>

  <!-- Répartition par parti -->
  <section class="card admin-card">
    <h2>Personnalités par parti</h2>
    <ul class="breakdown">
      <% stats.byParty.forEach(function(r){ %>
        <li><%- plogo(r.short, r.color, r.name) %> <span class="muted"><%= r.name %></span>
          <span class="eng num" style="margin-left:auto"><%= r.n %></span></li>
      <% }) %>
    </ul>
    <h2 style="margin-top:16px">Tiers de collecte</h2>
    <ul class="breakdown">
      <% stats.byTier.forEach(function(r){ %>
        <li><span class="chip">Tier <%= r.tier %></span><span class="eng num" style="margin-left:auto"><%= r.n %></span></li>
      <% }) %>
    </ul>
  </section>

  <!-- Collecteurs -->
  <section class="card admin-card">
    <h2>Collecteurs</h2>
    <ul class="breakdown">
      <% collectors.forEach(function(c){ %>
        <li>
          <span class="net"><%- icon(c.network,18) %><span class="lab"><%= NET_LABEL[c.network]||c.network %></span></span>
          <span class="muted"><%= c.kind==='paid'?'payant':'gratuit' %></span>
          <button class="mini <%= c.enabled?'on':'off' %>" data-toggle="<%= c.network %>" style="margin-left:auto"><%= c.enabled?'ON':'OFF' %></button>
        </li>
      <% }) %>
    </ul>
    <p class="muted" style="font-size:12.5px;margin-top:10px">⚠ Les payants (monid.ai) restent OFF tant que la clé n'est pas configurée + <code>ENABLE_PAID=1</code>.</p>
  </section>

  <!-- Actions -->
  <section class="card admin-card">
    <h2>Actions</h2>
    <div class="actions">
      <button id="recompute">↻ Recalculer les scores</button>
      <a class="btn-ghost" href="/" >Voir le classement</a>
    </div>
    <p class="muted" style="font-size:12.5px;margin-top:10px">Le recalcul régénère <code>account_stats</code> (posts/sem, qualité, reach, watch_score) pour tous les comptes actifs.</p>
  </section>

  <!-- Ajouter une personnalité -->
  <section class="card admin-card">
    <h2>Ajouter une personnalité</h2>
    <form class="stack" onsubmit="return addPerson(event)">
      <input name="display_name" placeholder="Nom complet (ex: Sophie Binet)" required>
      <div class="row">
        <select name="party_id">
          <option value="">— Parti —</option>
          <% parties.forEach(function(pt){ %><option value="<%= pt.id %>"><%= pt.name %> (<%= pt.short %>)</option><% }) %>
        </select>
        <label class="check"><input type="checkbox" name="is_public_figure"> Hors mandat</label>
      </div>
      <button type="submit">Créer</button>
    </form>
  </section>

  <!-- Ajouter un compte -->
  <section class="card admin-card">
    <h2>Ajouter un compte</h2>
    <form class="stack" onsubmit="return addAccount(event)">
      <div class="row">
        <select name="network" required>
          <option value="x">X</option><option value="instagram">Instagram</option>
          <option value="facebook">Facebook</option><option value="tiktok">TikTok</option>
          <option value="youtube">YouTube</option><option value="twitch">Twitch</option>
        </select>
        <input name="handle" placeholder="handle (sans @)" required>
      </div>
      <input name="url" placeholder="URL du profil (optionnel)">
      <input id="acc-person-search" placeholder="Rattacher à… (rechercher, vide = standalone)" autocomplete="off">
      <input type="hidden" name="person_id" id="acc-person-id">
      <div id="acc-person-results" class="results-pop"></div>
      <button type="submit">Ajouter le compte</button>
    </form>
  </section>
</div>

<!-- Gestion des comptes -->
<section>
  <h2>Comptes suivis (top 60 par score)</h2>
  <input id="acc-filter" placeholder="Filtrer par nom / handle…" style="margin:6px 0 12px;width:100%;max-width:340px">
  <table class="ranking" id="acc-table">
    <thead><tr><th>Personnalité</th><th>Parti</th><th>Réseau</th><th class="num">Abonnés</th><th>Tier</th><th class="num">Score</th><th></th></tr></thead>
    <tbody>
    <% accounts.forEach(function(a){ %>
      <tr data-row="<%= (a.display_name||'')+' @'+a.handle %>">
        <td><% if (a.person_id){ %><a class="pname" href="/person/<%= a.person_id %>"><%= a.display_name %></a><% } else { %><em>standalone</em><% } %></td>
        <td><%- plogo(a.party_short, a.party_color, a.party_name) %></td>
        <td><span class="net"><%- icon(a.network,18) %></span> <span class="muted">@<%= a.handle %></span></td>
        <td class="num"><%= fmt(a.followers) %></td>
        <td>
          <select class="mini-sel" data-tier="<%= a.id %>">
            <% ['A','B','C'].forEach(function(t){ %><option value="<%= t %>" <%= a.tier===t?'selected':'' %>><%= t %></option><% }) %>
          </select>
        </td>
        <td class="num"><strong><%= a.watch_score!=null?a.watch_score.toFixed(2):'—' %></strong></td>
        <td><button class="mini danger" data-del="<%= a.id %>">✕</button></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</section>

<script>
const toast = (m,ok=true)=>{ const t=document.getElementById('toast'); t.textContent=m; t.style.color=ok?'var(--vert)':'#ff8091'; setTimeout(()=>t.textContent='',3500); };
async function api(url,opt={}){ const r=await fetch(url,{headers:{'Content-Type':'application/json'},...opt}); const j=await r.json().catch(()=>({})); return {ok:r.ok,j,status:r.status}; }

async function addPerson(e){ e.preventDefault();
  const f=e.target, b=Object.fromEntries(new FormData(f)); b.is_public_figure=f.is_public_figure.checked?1:0;
  const {ok,j}=await api('/api/persons',{method:'POST',body:JSON.stringify(b)});
  if(ok){ toast('Personnalité créée #'+j.id); f.reset(); } else toast(j.error||'Erreur',false); return false; }

async function addAccount(e){ e.preventDefault();
  const f=e.target, b=Object.fromEntries(new FormData(f));
  const {ok,j}=await api('/api/accounts',{method:'POST',body:JSON.stringify(b)});
  if(ok){ toast('Compte ajouté #'+j.id); f.reset(); document.getElementById('acc-person-id').value=''; } else toast(j.error||('Erreur '+ (j.error||'')),false); return false; }

document.getElementById('recompute').addEventListener('click', async ()=>{
  const {ok,j}=await api('/api/recompute',{method:'POST'});
  toast(ok?('Scores recalculés ('+j.accounts+' comptes)'):'Erreur', ok); if(ok) setTimeout(()=>location.reload(),800); });

document.querySelectorAll('[data-toggle]').forEach(btn=>btn.addEventListener('click', async ()=>{
  const {ok,j}=await api('/api/collectors/'+btn.dataset.toggle+'/toggle',{method:'POST'});
  if(ok){ btn.textContent=j.enabled?'ON':'OFF'; btn.className='mini '+(j.enabled?'on':'off'); toast('Collecteur '+btn.dataset.toggle+' '+(j.enabled?'activé':'désactivé')); } }));

document.querySelectorAll('[data-del]').forEach(btn=>btn.addEventListener('click', async ()=>{
  if(!confirm('Supprimer ce compte ?')) return;
  const {ok}=await api('/api/accounts/'+btn.dataset.del,{method:'DELETE'});
  if(ok){ btn.closest('tr').remove(); toast('Compte supprimé'); } }));

document.querySelectorAll('[data-tier]').forEach(sel=>sel.addEventListener('change', async ()=>{
  const {ok}=await api('/api/accounts/'+sel.dataset.tier,{method:'PATCH',body:JSON.stringify({tier:sel.value})});
  toast(ok?'Tier mis à jour':'Erreur', ok); }));

// Filtre table
document.getElementById('acc-filter').addEventListener('input', e=>{
  const q=e.target.value.toLowerCase();
  document.querySelectorAll('#acc-table tbody tr').forEach(tr=>{
    tr.style.display = tr.dataset.row.toLowerCase().includes(q)?'':'none'; }); });

// Recherche personne pour rattacher un compte
const ps=document.getElementById('acc-person-search'), pr=document.getElementById('acc-person-results'), pid=document.getElementById('acc-person-id');
let pt; ps.addEventListener('input', ()=>{ clearTimeout(pt); pt=setTimeout(async ()=>{
  const q=ps.value.trim(); if(!q){ pr.innerHTML=''; pid.value=''; return; }
  const {j}=await api('/api/persons?q='+encodeURIComponent(q));
  pr.innerHTML=(j||[]).slice(0,6).map(p=>'<a class="chip" data-pid="'+p.id+'">'+p.display_name+'</a>').join(''); },200); });
pr.addEventListener('click', e=>{ const a=e.target.closest('[data-pid]'); if(!a) return;
  pid.value=a.dataset.pid; ps.value=a.textContent; pr.innerHTML=''; });
</script>

<%- include('../partials/foot') %>
